# ─── SpendSmart Backend Environment Variables ─────────────────────────────────
# Copy this file to .env and fill in your values

# Flask secret key (change this to a random string in production)
SECRET_KEY=your-super-secret-key-change-this

# Database (SQLite for local, PostgreSQL for production)
DATABASE_URL=sqlite:///spendsmart.db

# Groq API Key — get free key at console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Frontend URL (for CORS) — update for production
FRONTEND_URL=http://localhost:5500

# Port
PORT=5000

# Debug mode (set to false in production)
FLASK_DEBUG=true
